registry=https://artifacts.procoretech.com/artifactory/api/npm/npm/
always-auth=true
@procore:registry=https://artifacts.procoretech.com/artifactory/api/npm/npm/

# npm v7+ enforces peers strictly; Yarn often resolves this @procore/* tree without this flag.
# Keeps `npm install` / `npx` usable alongside Yarn until upstream peer ranges fully align.
legacy-peer-deps=true
